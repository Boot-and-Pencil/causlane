#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
if command -v readlink >/dev/null 2>&1; then
  SCRIPT_PATH="$(readlink -f "$SCRIPT_PATH")"
fi
ROOT="$(cd -- "$(dirname -- "$SCRIPT_PATH")/.." && pwd -P)"

if [ -x /home/linuxbrew/.linuxbrew/bin/brew ]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

if [ -x /home/linuxbrew/.linuxbrew/opt/dotnet@8/libexec/dotnet ]; then
  export DOTNET_ROOT="/home/linuxbrew/.linuxbrew/opt/dotnet@8/libexec"
  export PATH="$DOTNET_ROOT:$PATH"
elif [ -x /home/linuxbrew/.linuxbrew/opt/dotnet/libexec/dotnet ]; then
  export DOTNET_ROOT="/home/linuxbrew/.linuxbrew/opt/dotnet/libexec"
  export PATH="$DOTNET_ROOT:$PATH"
fi

export FORMAL_SMOKE_TMPDIR="${FORMAL_SMOKE_TMPDIR:-$ROOT/.agent-state/formal-smoke/tmp}"
export CARGO_TARGET_DIR="${CARGO_TARGET_DIR:-$ROOT/.agent-state/formal-smoke/cargo-target}"
if [ -d "$ROOT/.tools/elan/home" ]; then
  export ELAN_HOME="${ELAN_HOME:-$ROOT/.tools/elan/home}"
fi
export DOTNET_CLI_TELEMETRY_OPTOUT=1
export DOTNET_NOLOGO=1
export DOTNET_SKIP_FIRST_TIME_EXPERIENCE=1
export PATH="$ROOT/.tools/verus_dist/verus-x86-linux:$ROOT/.tools/elan/home/bin:$HOME/.dotnet/tools:$HOME/.cargo/bin:$PATH"

mkdir -p "$FORMAL_SMOKE_TMPDIR" "$CARGO_TARGET_DIR"

if [ "${1:-}" = "--source" ]; then
  return 0 2>/dev/null || exit 0
fi

exec "$@"
