#!/usr/bin/env python3
"""Generate or check the product-track concatenated reference bundle."""

from __future__ import annotations

import argparse
import difflib
import sys
from pathlib import Path


ROOT = Path(__file__).resolve().parents[1]
TRACK = ROOT / "docs" / "product-track"
BUNDLE = TRACK / "causlane_product_track_full_ru.md"


def source_paths() -> list[Path]:
    numbered = sorted(
        path
        for path in TRACK.glob("[0-9][0-9]-*.md")
        if path.name != BUNDLE.name
    )
    return [TRACK / "README.md", *numbered]


def render() -> str:
    chunks = [
        "\n".join(
            [
                "# Causlane product development track - generated bundle",
                "",
                "<!--",
                "Generated by tools/product-track-bundle.",
                "Do not edit this file directly; edit the source files named below.",
                "-->",
            ]
        )
    ]
    for path in source_paths():
        rel = path.relative_to(TRACK).as_posix()
        text = path.read_text(encoding="utf-8").rstrip()
        chunks.append(f"---\n\n<!-- source: {rel} -->\n\n{text}")
    return "\n\n".join(chunks).rstrip() + "\n"


def check() -> int:
    expected = render()
    actual = BUNDLE.read_text(encoding="utf-8") if BUNDLE.exists() else ""
    if actual == expected:
        print("product-track-bundle: OK")
        return 0
    diff = difflib.unified_diff(
        actual.splitlines(),
        expected.splitlines(),
        fromfile=BUNDLE.relative_to(ROOT).as_posix(),
        tofile="generated",
        lineterm="",
    )
    print("product-track-bundle: FAILED", file=sys.stderr)
    for line in diff:
        print(line, file=sys.stderr)
    return 1


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser()
    mode = parser.add_mutually_exclusive_group()
    mode.add_argument("--write", action="store_true", help="rewrite the bundle")
    mode.add_argument("--check", action="store_true", help="verify the bundle")
    args = parser.parse_args(argv)

    if args.write:
        BUNDLE.write_text(render(), encoding="utf-8")
        return 0
    if args.check:
        return check()
    print(render(), end="")
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
