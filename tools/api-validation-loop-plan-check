#!/usr/bin/env python3
"""Validate the M12.5 API validation loop planning surface."""

from __future__ import annotations

import ast
import json
import re
import sys
from pathlib import Path
from typing import Any


ROOT = Path(__file__).resolve().parents[1]
TRACK = ROOT / "docs" / "product-track"
ARTIFACT = TRACK / "api-validation-loop-plan.json"
ROADMAP_JSON = TRACK / "roadmap.json"
ROADMAP_YAML = TRACK / "roadmap.yaml"
PRODUCT_MAP = TRACK / "01-product-track-map.md"
CATALOG = TRACK / "02-milestone-catalog.md"
STAGE = TRACK / "stages" / "s12-beta-ecosystem.md"
MILESTONE_12_5 = TRACK / "milestones" / "m12.5-api-validation-loop.md"
MILESTONE_12_6 = TRACK / "milestones" / "m12.6-semver-pre-1.0-freeze-plan.md"
README = TRACK / "README.md"
START_GATE = TRACK / "11-implementation-start-gate.md"
EXAMPLES_CHECK = ROOT / "tools" / "examples-check"
FUZZ_MANIFEST = ROOT / "fuzz" / "Cargo.toml"
FUZZ_TARGETS = ROOT / "fuzz" / "fuzz_targets"
BENCH_MATRIX = TRACK / "bench-suite-matrix.json"

REQUIRED_ARTIFACT = "causlane.api-validation-loop-plan.v1"
REQUIRED_MILESTONE = "M12.5"
REQUIRED_TITLE = "API validation loop"
FORBIDDEN_TITLE = "DX feedback loop"
REQUIRED_LANES = {
    "synthetic_examples",
    "property_fuzz",
    "performance_scale",
    "api_feedback",
}
REQUIRED_TERMINAL = {"needs_api_change", "accepted_for_freeze"}
REQUIRED_INVENTORY_STATUS = "seeded"
REQUIRED_SURFACES = {
    "public_facade_and_core_kernel",
    "contracts_registry_bundle_plan_hash",
    "replay_scenario_explain",
    "runtime_dispatch_audit_projection",
}
REQUIRED_SURFACE_LANES = {
    "synthetic_examples",
    "property_fuzz",
    "performance_scale",
}
REQUIRED_EVIDENCE_KINDS = {
    "example_marker",
    "rust_test",
    "fuzz_target",
    "bench",
}
REQUIRED_DOC_TOKENS = {
    "API validation loop",
    "realistic synthetic examples",
    "property/fuzz",
    "performance scale",
    "accepted_for_freeze",
}
REQUIRED_FREEZE_TOKENS = {
    "M12.5",
    "validation evidence",
    "terminal classification",
    "freeze",
}


def reject_duplicate_keys(pairs: list[tuple[str, Any]]) -> dict[str, Any]:
    result: dict[str, Any] = {}
    for key, value in pairs:
        if key in result:
            raise ValueError(f"duplicate JSON key: {key}")
        result[key] = value
    return result


def read(path: Path, errors: list[str]) -> str:
    try:
        return path.read_text(encoding="utf-8")
    except OSError as error:
        errors.append(f"{path.relative_to(ROOT)}: {error}")
        return ""


def load_json(path: Path, errors: list[str]) -> dict[str, Any]:
    try:
        return json.loads(
            path.read_text(encoding="utf-8"),
            object_pairs_hook=reject_duplicate_keys,
        )
    except (OSError, json.JSONDecodeError, ValueError) as error:
        errors.append(f"{path.relative_to(ROOT)}: {error}")
        return {}


def expect(condition: bool, errors: list[str], message: str) -> None:
    if not condition:
        errors.append(message)


def string_literals(path: Path, errors: list[str]) -> set[str]:
    try:
        tree = ast.parse(path.read_text(encoding="utf-8"))
    except (OSError, SyntaxError) as error:
        errors.append(f"{path.relative_to(ROOT)}: {error}")
        return set()
    return {
        node.value
        for node in ast.walk(tree)
        if isinstance(node, ast.Constant) and isinstance(node.value, str)
    }


def rust_test_exists(path: Path, function: str, errors: list[str]) -> bool:
    source = read(path, errors)
    return re.search(rf"\bfn\s+{re.escape(function)}\b", source) is not None


def fuzz_targets(errors: list[str]) -> set[str]:
    manifest = read(FUZZ_MANIFEST, errors)
    declared = set(re.findall(r'(?m)^name\s*=\s*"([^"]+)"', manifest))
    declared.discard("causlane-fuzz")
    existing = {path.stem for path in FUZZ_TARGETS.glob("*.rs")}
    return declared & existing


def bench_ids(errors: list[str]) -> set[str]:
    matrix = load_json(BENCH_MATRIX, errors)
    benchmarks = matrix.get("benchmarks")
    if not isinstance(benchmarks, list):
        errors.append("bench-suite-matrix benchmarks must be a list")
        return set()
    ids: set[str] = set()
    for benchmark in benchmarks:
        if isinstance(benchmark, dict) and isinstance(benchmark.get("id"), str):
            ids.add(benchmark["id"])
    return ids


def validate_evidence(
    evidence: dict[str, Any],
    *,
    example_markers: set[str],
    fuzz_target_ids: set[str],
    benchmark_ids: set[str],
    errors: list[str],
    context: str,
) -> str | None:
    kind = evidence.get("kind")
    if kind not in REQUIRED_EVIDENCE_KINDS:
        errors.append(f"{context}: evidence kind must be one of {sorted(REQUIRED_EVIDENCE_KINDS)}")
        return None

    if kind == "example_marker":
        token = evidence.get("token")
        expect(
            isinstance(token, str) and token in example_markers,
            errors,
            f"{context}: example_marker token must exist in tools/examples-check",
        )
        return kind

    if kind == "rust_test":
        raw_path = evidence.get("path")
        function = evidence.get("function")
        if not isinstance(raw_path, str) or not isinstance(function, str):
            errors.append(f"{context}: rust_test evidence requires path and function strings")
            return kind
        path = ROOT / raw_path
        expect(
            path.is_file() and rust_test_exists(path, function, errors),
            errors,
            f"{context}: rust_test {raw_path}::{function} not found",
        )
        return kind

    if kind == "fuzz_target":
        target = evidence.get("target")
        expect(
            isinstance(target, str) and target in fuzz_target_ids,
            errors,
            f"{context}: fuzz_target must exist in verification/fuzz/Cargo.toml and verification/fuzz/fuzz_targets",
        )
        return kind

    if kind == "bench":
        benchmark = evidence.get("benchmark")
        expect(
            isinstance(benchmark, str) and benchmark in benchmark_ids,
            errors,
            f"{context}: bench benchmark must exist in bench-suite-matrix.json",
        )
        return kind

    return kind


def validate_artifact(artifact: dict[str, Any], errors: list[str]) -> None:
    expect(
        artifact.get("artifact") == REQUIRED_ARTIFACT,
        errors,
        f"artifact must be {REQUIRED_ARTIFACT}",
    )
    expect(
        artifact.get("milestone") == REQUIRED_MILESTONE,
        errors,
        "milestone must be M12.5",
    )
    expect(artifact.get("status") == "planned", errors, "status must remain planned")

    dependency = artifact.get("freeze_dependency")
    if not isinstance(dependency, dict):
        errors.append("freeze_dependency must be an object")
    else:
        expect(
            dependency.get("milestone") == "M12.6",
            errors,
            "freeze_dependency milestone must be M12.6",
        )
        rule = dependency.get("rule")
        expect(
            isinstance(rule, str)
            and "must not claim freeze readiness" in rule
            and "terminal classification" in rule,
            errors,
            "freeze_dependency rule must block freeze readiness before terminal classification",
        )

    lanes = artifact.get("lanes")
    if not isinstance(lanes, list):
        errors.append("lanes must be a list")
        seen_lanes: set[str] = set()
    else:
        seen_lanes = set()
        for lane in lanes:
            if not isinstance(lane, dict):
                errors.append("lane entries must be objects")
                continue
            lane_id = lane.get("lane")
            if not isinstance(lane_id, str):
                errors.append("lane entry missing string lane")
                continue
            seen_lanes.add(lane_id)
            expect(
                lane.get("status") == "planned",
                errors,
                f"{lane_id}: status must be planned",
            )
            expect(
                isinstance(lane.get("goal"), str) and bool(lane["goal"].strip()),
                errors,
                f"{lane_id}: goal must be non-empty",
            )
            expect(
                isinstance(lane.get("terminal_evidence"), str)
                and bool(lane["terminal_evidence"].strip()),
                errors,
                f"{lane_id}: terminal_evidence must be non-empty",
            )
    expect(
        seen_lanes == REQUIRED_LANES,
        errors,
        f"lanes must be exactly {sorted(REQUIRED_LANES)}",
    )

    terminal = artifact.get("terminal_classifications")
    if not isinstance(terminal, list) or not all(isinstance(item, str) for item in terminal):
        errors.append("terminal_classifications must be a string list")
    else:
        expect(
            set(terminal) == REQUIRED_TERMINAL,
            errors,
            f"terminal_classifications must be {sorted(REQUIRED_TERMINAL)}",
        )

    validate_inventory(artifact, errors)


def validate_inventory(artifact: dict[str, Any], errors: list[str]) -> None:
    expect(
        artifact.get("inventory_status") == REQUIRED_INVENTORY_STATUS,
        errors,
        f"inventory_status must be {REQUIRED_INVENTORY_STATUS}",
    )
    surfaces = artifact.get("selected_surfaces")
    if not isinstance(surfaces, list):
        errors.append("selected_surfaces must be a list")
        return

    example_markers = string_literals(EXAMPLES_CHECK, errors)
    fuzz_target_ids = fuzz_targets(errors)
    benchmark_ids = bench_ids(errors)
    seen_surfaces: set[str] = set()

    for surface in surfaces:
        if not isinstance(surface, dict):
            errors.append("selected_surfaces entries must be objects")
            continue
        surface_id = surface.get("id")
        if not isinstance(surface_id, str):
            errors.append("selected surface missing string id")
            continue
        if surface_id in seen_surfaces:
            errors.append(f"{surface_id}: duplicate selected surface id")
        seen_surfaces.add(surface_id)

        classification = surface.get("classification")
        expect(
            classification == "pending" or classification in REQUIRED_TERMINAL,
            errors,
            f"{surface_id}: classification must be pending or a terminal classification",
        )
        api_scope = surface.get("api_scope")
        expect(
            isinstance(api_scope, list)
            and bool(api_scope)
            and all(isinstance(entry, str) and entry.strip() for entry in api_scope),
            errors,
            f"{surface_id}: api_scope must be a non-empty string list",
        )

        lanes = surface.get("lanes")
        if not isinstance(lanes, list):
            errors.append(f"{surface_id}: lanes must be a list")
            continue
        lane_ids: set[str] = set()
        has_gap = False
        for lane in lanes:
            if not isinstance(lane, dict):
                errors.append(f"{surface_id}: lane entries must be objects")
                continue
            lane_id = lane.get("lane")
            if not isinstance(lane_id, str):
                errors.append(f"{surface_id}: lane entry missing string lane")
                continue
            context = f"{surface_id}/{lane_id}"
            if lane_id in lane_ids:
                errors.append(f"{context}: duplicate lane")
            lane_ids.add(lane_id)
            expect(
                lane.get("status") in {"seeded", "complete"},
                errors,
                f"{context}: status must be seeded or complete",
            )
            gap = lane.get("gap_before_freeze")
            if isinstance(gap, str) and gap.strip():
                has_gap = True
            evidence_items = lane.get("evidence")
            if not isinstance(evidence_items, list) or not evidence_items:
                errors.append(f"{context}: evidence must be a non-empty list")
                continue
            evidence_kinds: set[str] = set()
            for index, evidence in enumerate(evidence_items):
                if not isinstance(evidence, dict):
                    errors.append(f"{context}: evidence entries must be objects")
                    continue
                kind = validate_evidence(
                    evidence,
                    example_markers=example_markers,
                    fuzz_target_ids=fuzz_target_ids,
                    benchmark_ids=benchmark_ids,
                    errors=errors,
                    context=f"{context}/evidence[{index}]",
                )
                if kind:
                    evidence_kinds.add(kind)
            if lane_id == "synthetic_examples":
                expect(
                    evidence_kinds == {"example_marker"},
                    errors,
                    f"{context}: synthetic_examples must use example_marker evidence",
                )
            if lane_id == "property_fuzz":
                expect(
                    bool(evidence_kinds & {"rust_test", "fuzz_target"}),
                    errors,
                    f"{context}: property_fuzz must use rust_test or fuzz_target evidence",
                )
            if lane_id == "performance_scale":
                expect(
                    evidence_kinds == {"bench"},
                    errors,
                    f"{context}: performance_scale must use bench evidence",
                )

        expect(
            lane_ids == REQUIRED_SURFACE_LANES,
            errors,
            f"{surface_id}: lanes must be exactly {sorted(REQUIRED_SURFACE_LANES)}",
        )
        if classification in REQUIRED_TERMINAL:
            expect(
                not has_gap,
                errors,
                f"{surface_id}: terminal classification cannot be recorded while any lane has gap_before_freeze",
            )

    expect(
        seen_surfaces == REQUIRED_SURFACES,
        errors,
        f"selected_surfaces must be exactly {sorted(REQUIRED_SURFACES)}",
    )


def validate_roadmap(roadmap: dict[str, Any], errors: list[str]) -> None:
    milestones = roadmap.get("milestones")
    if not isinstance(milestones, dict):
        errors.append("roadmap milestones must be an object")
        return

    m125 = milestones.get("M12.5")
    m126 = milestones.get("M12.6")
    if not isinstance(m125, dict):
        errors.append("roadmap missing M12.5")
    else:
        expect(
            m125.get("title") == REQUIRED_TITLE,
            errors,
            "roadmap M12.5 title must be API validation loop",
        )
        description = m125.get("description")
        expect(
            isinstance(description, str)
            and all(
                token in description
                for token in ["synthetic examples", "property/fuzz", "performance scale"]
            ),
            errors,
            "roadmap M12.5 description must mention all validation lanes",
        )
    if not isinstance(m126, dict):
        errors.append("roadmap missing M12.6")
    else:
        description = m126.get("description")
        expect(
            isinstance(description, str) and "M12.5 validation evidence" in description,
            errors,
            "roadmap M12.6 description must consume M12.5 validation evidence",
        )


def validate_docs(errors: list[str]) -> None:
    m125_text = read(MILESTONE_12_5, errors)
    m126_text = read(MILESTONE_12_6, errors)
    combined = "\n".join(
        read(path, errors)
        for path in [PRODUCT_MAP, CATALOG, STAGE, README, START_GATE, ROADMAP_YAML]
    )

    expect(FORBIDDEN_TITLE not in combined, errors, f"docs must not still say {FORBIDDEN_TITLE}")
    for token in REQUIRED_DOC_TOKENS:
        expect(token in m125_text, errors, f"M12.5 milestone missing token: {token}")
        expect(token in combined, errors, f"product-track docs missing token: {token}")
    for token in REQUIRED_FREEZE_TOKENS:
        expect(token in m126_text, errors, f"M12.6 milestone missing freeze token: {token}")


def main() -> int:
    errors: list[str] = []
    artifact = load_json(ARTIFACT, errors)
    roadmap = load_json(ROADMAP_JSON, errors)
    validate_artifact(artifact, errors)
    validate_roadmap(roadmap, errors)
    validate_docs(errors)

    if errors:
        print("api-validation-loop-plan-check: FAILED", file=sys.stderr)
        for error in errors:
            print(f"  - {error}", file=sys.stderr)
        return 1

    print("api-validation-loop-plan-check: OK")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
