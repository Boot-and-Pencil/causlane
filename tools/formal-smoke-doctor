#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import os
import shutil
import subprocess
import sys
from pathlib import Path


ROOT = Path(__file__).resolve().parents[1]


def git(args: list[str]) -> str:
    try:
        return subprocess.check_output(["git", "-C", str(ROOT), *args], text=True, stderr=subprocess.DEVNULL).strip()
    except Exception:
        return ""


def repo_name() -> str:
    remote = git(["config", "--get", "remote.origin.url"])
    if remote:
        name = remote.rstrip("/").rsplit("/", 1)[-1]
        if name.endswith(".git"):
            name = name[:-4]
        if name:
            return name
    return ROOT.name


def env() -> dict[str, str]:
    e = os.environ.copy()
    e["DOTNET_CLI_TELEMETRY_OPTOUT"] = "1"
    e["DOTNET_NOLOGO"] = "1"
    e["DOTNET_SKIP_FIRST_TIME_EXPERIENCE"] = "1"
    if (ROOT / ".tools/elan/home").is_dir():
        e.setdefault("ELAN_HOME", str(ROOT / ".tools/elan/home"))
    dotnet8 = Path("/home/linuxbrew/.linuxbrew/opt/dotnet@8/libexec")
    dotnet = Path("/home/linuxbrew/.linuxbrew/opt/dotnet/libexec")
    if (dotnet8 / "dotnet").is_file():
        e["DOTNET_ROOT"] = str(dotnet8)
        dotnet_path = str(dotnet8)
    elif (dotnet / "dotnet").is_file():
        e["DOTNET_ROOT"] = str(dotnet)
        dotnet_path = str(dotnet)
    else:
        dotnet_path = ""
    paths = [
        str(ROOT / ".tools/verus_dist/verus-x86-linux"),
        str(ROOT / ".tools/elan/home/bin"),
        dotnet_path,
        str(Path.home() / ".dotnet/tools"),
        str(Path.home() / ".cargo/bin"),
        e.get("PATH", ""),
    ]
    e["PATH"] = ":".join(paths)
    return e


def version(binary: str, args: list[str]) -> str:
    path = shutil.which(binary, path=env()["PATH"])
    if not path:
        return ""
    try:
        proc = subprocess.run([path, *args], text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, env=env(), timeout=20)
    except Exception:
        return ""
    text = (proc.stdout.strip() or proc.stderr.strip()).splitlines()
    if proc.returncode != 0:
        return "ERROR: " + (text[0] if text else f"exit {proc.returncode}")
    return text[0] if text else ""


def command_report(name: str, args: list[str]) -> dict:
    path = shutil.which(name, path=env()["PATH"])
    ver = version(name, args) if path else ""
    usable = bool(path) and not ver.startswith("ERROR:")
    return {"found": usable, "path": path or "", "version": ver}


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--require", choices=["none", "all"], default="all")
    args = parser.parse_args()

    commands = {
        "cargo": command_report("cargo", ["--version"]),
        "cargo-fuzz": command_report("cargo-fuzz", ["--version"]),
        "cargo-kani": command_report("cargo-kani", ["--version"]),
        "kani": command_report("kani", ["--version"]),
        "verus": command_report("verus", ["--version"]),
        "lean": command_report("lean", ["--version"]),
        "lake": command_report("lake", ["--version"]),
        "p": command_report("p", ["--version"]),
        "z3": command_report("z3", ["--version"]),
        "dotnet": command_report("dotnet", ["--version"]),
        "python3": command_report("python3", ["--version"]),
    }
    required = ["cargo", "cargo-fuzz", "cargo-kani", "verus", "lean", "p", "z3", "python3"]
    failures = [f"missing_{name}" for name in required if not commands[name]["found"]]
    artifacts = {
        "model": (ROOT / "verification/formal-smoke/model/traces.json").exists(),
        "rust": (ROOT / "verification/formal-smoke/rust/Cargo.toml").exists(),
        "kani": (ROOT / "verification/formal-smoke/kani/README.md").exists(),
        "verus": (ROOT / "verification/formal-smoke/verus/smoke.rs").exists(),
        "p-lang": (ROOT / "verification/formal-smoke/p-lang/Smoke.p").exists(),
        "lean4": (ROOT / "verification/formal-smoke/lean4/Smoke.lean").exists(),
        "property": (ROOT / "verification/formal-smoke/property/README.md").exists(),
        "fuzz": (ROOT / "verification/formal-smoke/fuzz/Cargo.toml").exists(),
    }
    failures.extend([f"missing_artifact_{name}" for name, ok in artifacts.items() if not ok])
    if args.require == "none":
        failures = []
    report = {
        "schema_version": "hopium.formal_smoke.doctor.v1",
        "status": "fail" if failures else "ok",
        "repo": repo_name(),
        "commands": commands,
        "artifacts": artifacts,
        "failures": failures,
    }
    if args.json:
        print(json.dumps(report, indent=2, sort_keys=True))
    else:
        print(f"formal-doctor: {report['status']} failures={len(failures)}")
        for failure in failures:
            print(failure)
    return 1 if failures else 0


if __name__ == "__main__":
    raise SystemExit(main())
