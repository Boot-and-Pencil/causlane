#!/usr/bin/env bash
set -euo pipefail

HOST="${CI_DISPATCHER_HOST:-ci-dispatcher.lan}"
REPO="${CI_DISPATCHER_REPO:-/workspace/repo}"
CONNECT_TIMEOUT="${CI_DISPATCHER_CONNECT_TIMEOUT:-10}"
FUZZ_TOOLCHAIN="${CI_DISPATCHER_FUZZ_TOOLCHAIN:-nightly-2025-11-21}"
FUZZ_TARGET="${CI_DISPATCHER_FUZZ_TARGET:-requirement_from_tokens}"
FUZZ_ARTIFACTS="${CI_DISPATCHER_FUZZ_ARTIFACTS:-/tmp/causlane-fuzz-artifacts}"
SYNC=1

usage() {
  cat <<'EOF'
Usage: tools/ci-dispatcher-preflight [OPTIONS]

Run the Causlane CI/property/fuzz smoke gate on the configured dispatcher host.

Options:
  --host HOST          SSH host (default: ci-dispatcher.lan)
  --repo PATH          Checkout path on the host (default: /workspace/repo)
  --connect-timeout N  SSH connect timeout in seconds (default: 10)
  --fuzz-toolchain T   Rust toolchain for cargo-fuzz (default: nightly-2025-11-21)
  --fuzz-target T      Short fuzz target to execute (default: requirement_from_tokens)
  --fuzz-artifacts P   Fuzz artifact prefix directory (default: /tmp/causlane-fuzz-artifacts)
  --no-sync            Do not fetch/fast-forward the remote checkout first
  -h, --help           Show this help

Environment overrides:
  CI_DISPATCHER_HOST, CI_DISPATCHER_REPO, CI_DISPATCHER_CONNECT_TIMEOUT,
  CI_DISPATCHER_FUZZ_TOOLCHAIN, CI_DISPATCHER_FUZZ_TARGET,
  CI_DISPATCHER_FUZZ_ARTIFACTS.
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --host)
      HOST="${2:?missing value for --host}"
      shift 2
      ;;
    --repo)
      REPO="${2:?missing value for --repo}"
      shift 2
      ;;
    --connect-timeout)
      CONNECT_TIMEOUT="${2:?missing value for --connect-timeout}"
      shift 2
      ;;
    --fuzz-toolchain)
      FUZZ_TOOLCHAIN="${2:?missing value for --fuzz-toolchain}"
      shift 2
      ;;
    --fuzz-target)
      FUZZ_TARGET="${2:?missing value for --fuzz-target}"
      shift 2
      ;;
    --fuzz-artifacts)
      FUZZ_ARTIFACTS="${2:?missing value for --fuzz-artifacts}"
      shift 2
      ;;
    --no-sync)
      SYNC=0
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "ci-dispatcher-preflight: unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

ssh_opts=(-o BatchMode=yes -o ConnectTimeout="$CONNECT_TIMEOUT")

echo "ci-dispatcher preflight"
echo "  host: $HOST"
echo "  repo: $REPO"
echo "  fuzz toolchain: $FUZZ_TOOLCHAIN"
echo "  fuzz target: $FUZZ_TARGET"

ssh "${ssh_opts[@]}" "$HOST" 'bash -s' -- \
  "$REPO" "$FUZZ_TOOLCHAIN" "$FUZZ_TARGET" "$FUZZ_ARTIFACTS" "$SYNC" <<'REMOTE'
set -euo pipefail

repo="$1"
fuzz_toolchain="$2"
fuzz_target="$3"
fuzz_artifacts="$4"
sync_checkout="$5"

step() {
  printf '\n==> %s\n' "$*"
}

require_tool() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "missing required tool on ci-dispatcher: $1" >&2
    exit 10
  fi
}

if [[ ! -d "$repo" ]]; then
  echo "remote checkout does not exist: $repo" >&2
  exit 11
fi

cd "$repo"

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "remote path is not a git checkout: $repo" >&2
  exit 12
fi

if [[ "$sync_checkout" == "1" ]]; then
  step "reset from origin/main"
  git status --short --branch
  git fetch origin main
  git checkout -B main origin/main
  git reset --hard origin/main
  git clean -ffd
else
  step "checkout cleanliness"
  git status --short --branch
  if [[ -n "$(git status --porcelain)" ]]; then
    echo "remote checkout has uncommitted changes: $repo" >&2
    exit 13
  fi
fi

step "index parity"
local_head="$(git rev-parse HEAD)"
origin_head="$(git rev-parse origin/main)"
remote_head="$(git ls-remote origin refs/heads/main | awk '{print $1}')"
printf 'HEAD:        %s\n' "$local_head"
printf 'origin/main: %s\n' "$origin_head"
printf 'remote main: %s\n' "$remote_head"
if [[ "$local_head" != "$origin_head" || "$local_head" != "$remote_head" ]]; then
  echo "remote checkout is not at origin/main" >&2
  exit 15
fi

step "tool inventory"
for tool in bash git python3 jq just cargo rustc rustup cargo-fuzz cargo-kani z3 java javac dotnet; do
  require_tool "$tool"
  printf '%-12s %s\n' "$tool" "$(command -v "$tool")"
done
cargo --version
rustc --version
cargo +"$fuzz_toolchain" --version
rustc +"$fuzz_toolchain" --version
cargo-fuzz --version
cargo-kani --version
z3 --version
java -version 2>&1 | sed -n '1,2p'
javac -version 2>&1
dotnet --version

step "formal doctor local_smoke"
mkdir -p target/causlane
python3 tools/formal-doctor --json --profile all --lane local_smoke \
  > target/causlane/ci-dispatcher-formal-doctor.json
jq -e '.status == "ok"' target/causlane/ci-dispatcher-formal-doctor.json >/dev/null

step "property smoke"
./tools/cargo-dev test -p causlane-formal --test proptest_smoke --locked
./tools/cargo-dev test -p causlane-core --test proptest_protocol_properties --locked
./tools/cargo-dev test -p causlane-replay --test proptest_parse_boundaries --locked

step "fuzz compile"
REAL_CARGO="$(command -v cargo)" DEVINFRA_ALLOW_DIRECT_CARGO=1 \
  ./tools/cargo +"$fuzz_toolchain" test --manifest-path fuzz/Cargo.toml --no-run --bins --locked

step "fuzz one-run smoke"
mkdir -p "$fuzz_artifacts"
REAL_CARGO="$(command -v cargo)" DEVINFRA_ALLOW_DIRECT_CARGO=1 \
  ./tools/cargo +"$fuzz_toolchain" fuzz run "$fuzz_target" -- \
  -runs=1 -artifact_prefix="${fuzz_artifacts%/}/"

step "post-run cleanliness"
git status --short --branch
if [[ -n "$(git status --porcelain)" ]]; then
  echo "remote checkout changed during preflight: $repo" >&2
  exit 16
fi

step "preflight passed"
printf 'host=%s repo=%s head=%s\n' "$(hostname)" "$repo" "$local_head"
REMOTE
