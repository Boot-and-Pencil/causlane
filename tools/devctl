def cmd_env_exec(args: argparse.Namespace) -> int:
    root = repo_root()
    ensure_state_dirs(root)
    argv = list(args.argv)
    if argv and argv[0] == "--":
        argv = argv[1:]
    if not argv:
        raise SystemExit("env exec requires a command after --")
    env = effective_env(root)
    os.execvpe(argv[0], argv, env)
    return 127


class StateHandler(BaseHTTPRequestHandler):
    root: Path

    def log_message(self, format: str, *args: object) -> None:
        return

    def write_json(self, status: int, data: object) -> None:
        payload = json.dumps(data, indent=2, sort_keys=True).encode("utf-8") + b"\n"
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(payload)))
        self.end_headers()
        self.wfile.write(payload)

    def do_GET(self) -> None:  # noqa: N802
        root = self.root
        routes = {
            "/status": lambda: load_state_bundle(root),
            "/snapshot": lambda: snapshot(root),
            "/diagnostics": lambda: read_diagnostics_bundle(root, snapshot(root)),
            "/checker": lambda: summarize_checker(root, read_json(state_path(root, "checker.json"), {}), snapshot(root)),
            "/coverage": lambda: (load_state_bundle(root).get("coverage") or {}),
            "/prewarm": lambda: read_json(state_path(root, "prewarm-state.json"), {}),
            "/cache-key/dev": lambda: cache_key(root, "dev"),
            "/cache-key/coverage": lambda: cache_key(root, "coverage"),
        }
        producer = routes.get(self.path)
        if producer is None:
            self.write_json(404, {"error": "unknown endpoint"})
            return
        self.write_json(200, producer())


def cmd_state_api(args: argparse.Namespace) -> int:
    root = repo_root()
    ensure_state_dirs(root)
    host, port_text = args.listen.rsplit(":", 1)
    StateHandler.root = root
    server = ThreadingHTTPServer((host, int(port_text)), StateHandler)
    print(f"state-api listening on http://{args.listen}", flush=True)
    server.serve_forever()
    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="cli-checker development infrastructure control plane.")
    sub = parser.add_subparsers(dest="command", required=True)

    status = sub.add_parser("status")
    status.add_argument("--json", action="store_true")
    status.set_defaults(func=cmd_status)

    diagnostics = sub.add_parser("diagnostics")
    diagnostics.add_argument("--format", choices=["human", "json"], default="human")
    diagnostics.add_argument("--limit", type=int, default=50)
    diagnostics.add_argument("--require-fresh", action="store_true")
    diagnostics.set_defaults(func=cmd_diagnostics)

    prewarm_status = sub.add_parser("prewarm-status")
    prewarm_status.add_argument("--json", action="store_true")
    prewarm_status.set_defaults(func=cmd_prewarm_status)

    background = sub.add_parser("background")
    background.add_argument("action", choices=["stop", "resume"])
    background.add_argument("--reason", default="manual")
    background.add_argument("--quiet", action="store_true")
    background.set_defaults(func=cmd_background)

    doctor = sub.add_parser("doctor")
    doctor.set_defaults(func=cmd_doctor)

    coverage = sub.add_parser("coverage-summary")
    coverage.add_argument("--lcov", default="target/llvm-cov-target/lcov.info")
    coverage.set_defaults(func=cmd_coverage_summary)

    coverage_snapshot = sub.add_parser("write-coverage-snapshot")
    coverage_snapshot.add_argument("--lcov", default="target/llvm-cov-target/lcov.info")
    coverage_snapshot.add_argument("--quiet", action="store_true")
    coverage_snapshot.set_defaults(func=cmd_write_coverage_snapshot)

    coverage_clean = sub.add_parser("ensure-coverage-clean")
    coverage_clean.add_argument("--quiet", action="store_true")
    coverage_clean.set_defaults(func=cmd_ensure_coverage_clean)

    write_snapshot = sub.add_parser("write-snapshot")
    write_snapshot.add_argument("--quiet", action="store_true")
    write_snapshot.set_defaults(func=cmd_write_snapshot)

    env_parser = sub.add_parser("env")
    env_sub = env_parser.add_subparsers(dest="env_command", required=True)
    env_exec = env_sub.add_parser("exec")
    env_exec.add_argument("argv", nargs=argparse.REMAINDER)
    env_exec.set_defaults(func=cmd_env_exec)

    state_api = sub.add_parser("state-api")
    state_api.add_argument("--listen", default="127.0.0.1:7810")
    state_api.set_defaults(func=cmd_state_api)

    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
