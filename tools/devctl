def cmd_ensure_coverage_clean(args: argparse.Namespace) -> int:
    root = repo_root()
    ensure_state_dirs(root)
    key = cache_key(root, "coverage")
    snap = snapshot(root)
    marker_path = state_path(root, "coverage-clean-marker.json")
    marker = read_json(marker_path, {})
    current = {
        "cache_key_hash": key.get("hash"),
        "cargo_lock_hash": snap.get("cargo_lock_hash"),
        "cargo_config_hash": snap.get("cargo_config_hash"),
        "rust_toolchain_hash": snap.get("rust_toolchain_hash"),
    }
    if isinstance(marker, dict) and all(marker.get(name) == value for name, value in current.items()):
        if not args.quiet:
            print_json({"status": "ok", "cleaned": False, **current})
        return 0

    env = effective_env(root)
    coverage_target = root / "target/llvm-cov-target"
    env.update(
        {
            "CARGO_TARGET_DIR": str(coverage_target),
            "CARGO_LLVM_COV_TARGET_DIR": str(coverage_target),
            "CARGO_LLVM_COV_BUILD_DIR": str(coverage_target),
            "DEVINFRA_ALLOW_DIRECT_CARGO": "1",
        }
    )
    proc = subprocess.run(["cargo", "llvm-cov", "clean", "--workspace"], cwd=root, env=env)
    if proc.returncode != 0:
        return proc.returncode
    payload = {**current, "schema_version": 1, "cleaned_at": utc_now()}
    atomic_write_json(marker_path, payload)
    if not args.quiet:
        print_json({"status": "ok", "cleaned": True, **payload})
    return 0


