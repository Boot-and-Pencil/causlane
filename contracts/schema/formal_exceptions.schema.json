{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://causlane.local/schema/formal_exceptions.schema.json",
  "title": "Causlane Formal Exceptions Policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "exceptions"],
  "properties": {
    "schema_version": { "const": 1 },
    "_comment": { "type": "string" },
    "_exceptions_note": { "type": "string" },
    "exceptions": {
      "type": "array",
      "items": { "$ref": "#/$defs/exception" }
    },
    "scope_notes": {
      "type": "array",
      "items": { "$ref": "#/$defs/scope_note" }
    }
  },
  "$defs": {
    "exception": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "target",
        "allowed_until",
        "reason",
        "owner",
        "affects_invariants",
        "allowed_profiles",
        "forbidden_profiles"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "enum": ["alloy", "p", "kani", "verus", "lean4"] },
        "allowed_until": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
        "reason": { "type": "string", "minLength": 1 },
        "owner": { "type": "string", "minLength": 1 },
        "affects_invariants": {
          "type": "array",
          "items": { "$ref": "common.schema.json#/$defs/known_invariant_id" }
        },
        "allowed_profiles": {
          "type": "array",
          "items": { "type": "string", "enum": ["base", "rust", "ci", "proof", "all"] }
        },
        "forbidden_profiles": {
          "type": "array",
          "items": { "type": "string", "enum": ["base", "rust", "ci", "proof", "all"] }
        }
      }
    },
    "scope_note": {
      "type": "object",
      "additionalProperties": false,
      "required": ["invariant", "not_applicable_lanes", "reason"],
      "properties": {
        "invariant": { "$ref": "common.schema.json#/$defs/known_invariant_id" },
        "not_applicable_lanes": {
          "type": "array",
          "items": { "type": "string", "enum": ["replay", "alloy", "p", "kani", "verus", "lean4"] }
        },
        "reason": { "type": "string", "minLength": 1 }
      }
    }
  }
}
