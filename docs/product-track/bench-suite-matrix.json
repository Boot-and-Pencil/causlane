      "fixture": "release_promote_plan_material"
    },
    {
      "id": "bundle_load_from_json",
      "measures": "CompiledDispatchBundle::from_json_str",
      "fixture": "release_promote compiled bundle JSON"
    },
    {
      "id": "replay_verify_with_bundle",
      "measures": "ReplayTrace::verify_with_bundle",
      "fixture": "contracts/scenarios/release_promote_success.scenario.yaml"
    },
    {
      "id": "frontier_conflict_selection",
      "measures": "select_frontier",
